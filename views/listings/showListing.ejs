<% layout('/layouts/boilerplate') -%>
<script>
  const mapToken='<%=process.env.MAP_TOKEN%>';
  const coordinates=<%- JSON.stringify(listingShow.geometry.coordinates)%>;
</script>
<!-- Title -->
<h3 class="text-center mb-3 mt-3">
  <b><i><%=listingShow.title%></i></b>
</h3>

<!-- Main Card -->
<div class="row justify-content-center">
  <div class="col-12 col-md-10 col-lg-8">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
      <div class="ratio ratio-16x9">
        <img
          src="<%= listingShow.image.url %>"
          alt="<%= listingShow.title %>"
          class="w-100 h-100 object-fit-cover"
        />
      </div>
      <div class="card-body p-4">
        <p class="mb-1">
          <strong>Owned By:</strong>
          <i><b>@<%= listingShow.owner.username %></b></i>
        </p>
        <p class="text-muted mb-3">
          <b><i><%= listingShow.description %></i></b>
        </p>

        <ul class="list-unstyled mb-0">
          <li class="mb-1">
            <strong
              >&#8377;<%= listingShow.price.toLocaleString('en-in') %></strong
            >
            <span class="text-muted">/ Night</span>
          </li>
          <li class="mb-1">
            <strong>Location:</strong> <%= listingShow.location %>
          </li>
          <li><strong>Country:</strong> <%= listingShow.country %></li>
        </ul>
      </div>
    </div>
  </div>
</div>

<!-- Edit/Delete Buttons -->
<% if(currUser && currUser._id.equals(listingShow.owner._id)){ %>
<div class="d-flex justify-content-center gap-3 mb-4 flex-wrap">
  <form action="/listings/<%= listingShow._id %>/edit" method="GET">
    <button type="submit" class="btn btn-dark editBtn">Edit Listing</button>
  </form>
  <form action="/listings/<%= listingShow._id %>?_method=DELETE" method="POST">
    <button type="submit" class="btn btn-dark deleteBtn">Delete</button>
  </form>
</div>
<% } %>

<hr class="my-4" />

<!-- Leave a Review -->
<% if(currUser){ %>
<div class="row justify-content-center mb-5">
  <div class="col-12 col-md-10 col-lg-6">
    <h3 class="mb-3">Leave a Review</h3>
    <form
      action="/listings/<%= listingShow._id %>/reviews"
      method="POST"
      class="needs-validation"
      novalidate
    >
      <label for="rating" class="form-label">Rating</label>
      <fieldset class="starability-fade mb-3">
        <input
          type="radio"
          id="no-rate"
          class="input-no-rate"
          name="review[rating]"
          checked
          value="5"
          aria-label="No rating."
        />
        <input type="radio" id="first-rate1" name="review[rating]" value="5" />
        <label for="first-rate1" title="Terrible">1 star</label>
        <input type="radio" id="first-rate2" name="review[rating]" value="4" />
        <label for="first-rate2" title="Not good">2 stars</label>
        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
        <label for="first-rate3" title="Average">3 stars</label>
        <input type="radio" id="first-rate4" name="review[rating]" value="2" />
        <label for="first-rate4" title="Very good">4 stars</label>
        <input type="radio" id="first-rate5" name="review[rating]" value="1" />
        <label for="first-rate5" title="Amazing">5 stars</label>
      </fieldset>

      <label for="comment" class="form-label">Comments</label>
      <textarea
        name="review[comment]"
        id="comment"
        class="form-control mb-3"
        rows="6"
        required
      ></textarea>
      <div class="invalid-feedback mb-3">Please leave a Review</div>

      <button type="submit" class="btn btn-outline-dark">Submit</button>
    </form>
  </div>
</div>
<% } %>

<!-- Map -->
<div class="row justify-content-center">
  <div class="col-12 col-md-10 col-lg-8 mb-5">
    <h3>Where you'll be</h3>
    <div id="map" class="rounded-5 w-100" style="height: 25rem"></div>
  </div>
</div>

<!-- All Reviews -->
<% if(listingShow.reviews.length > 0){ %>
<h4 class="text-center mb-4">All Reviews</h4>
<div class="row justify-content-center" id="reviewsContainer">
  <% listingShow.reviews.forEach((review, i) => { %>
  <div
    class="col-12 col-md-5 col-lg-4 mb-3 review-card <%= i >= 3 ? 'd-none' : '' %>"
  >
    <!-- hide reviews beyond the first 3 -->
    <div class="card shadow-sm">
      <div class="card-body">
        <h5 class="card-title"><i>@<%=review.author.username%></i></h5>
        <p class="starability-result" data-rating="<%=review.rating%>"></p>
        <p class="card-text"><%=review.comment%></p>
        <% if(currUser && currUser._id.equals(review.author._id)){ %>
        <form
          action="/listings/<%=listingShow._id%>/reviews/<%=review._id%>?_method=DELETE"
          method="POST"
        >
          <button class="btn btn-sm btn-dark">Delete</button>
        </form>
        <% } %>
      </div>
    </div>
  </div>
  <% }) %>
</div>

<!-- Show More Button -->
<% if(listingShow.reviews.length > 3){ %>
<div class="text-center mt-3 mb-3">
  <button id="showMoreBtn" class="btn btn-outline-dark">
    Show All Reviews
  </button>
</div>
<% } %> <% } %>

<script src="/js/showListings.js"></script>
