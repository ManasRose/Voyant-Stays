<% layout('/layouts/boilerplate') -%>
<link rel="stylesheet" href="/../css/index.css" />

<body class="bg-light">
  <div class="container mt-3">
    <!-- 🔽 Filters Row (All Screens) -->
    <div class="d-flex justify-content-between align-items-center">
      <!-- Left side: Scrollable Filters -->
      <div class="d-flex flex-nowrap align-items-center me-3" id="filters">
        <%- include ("../includes/filters.ejs") %>
      </div>

      <!-- Right side: Tax toggle (hidden on md and smaller) -->
      <div class="tax-toggle d-none d-lg-flex align-items-center flex-shrink-0">
        <div class="form-check form-switch mb-0">
          <input
            class="form-check-input"
            type="checkbox"
            role="switch"
            id="switchCheckDefault"
          />
          <label class="form-check-label ms-1" for="switchCheckDefault">
            After Taxes
          </label>
        </div>
      </div>
    </div>

    <!-- 🔽 Listings Grid -->
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-1 g-4 mb-3">
      <% listings.forEach((listing, i) => { %>
      <div class="col">
        <a
          href="/listings/<%= listing._id %>"
          class="card-link text-decoration-none text-dark d-block h-100"
        >
          <div
            class="card listingCard border-0 shadow-sm rounded-4 overflow-hidden h-100 position-relative hover-card"
          >
            <!-- Image -->
            <div class="position-relative overflow-hidden">
              <img
                src="<%= listing.image.url %>"
                class="card-img-top listing-img"
                alt="<%= listing.title %>"
              />
              <div
                class="overlay d-flex justify-content-center align-items-center"
              >
                <span class="btn btn-danger rounded-pill px-4">
                  View Details
                </span>
              </div>
            </div>

            <!-- Card Body -->
            <div class="card-body">
              <div
                class="d-flex justify-content-between align-items-center mb-2"
              >
                <h5 class="card-title fw-bold mb-0"><%= listing.title %></h5>
                <span class="rating">
                  <span class="star">&#9733;</span>
                  <%= avgRatings[i] || "N/A" %>
                </span>
              </div>
              <p class="card-text text-muted small">
                <%= listing.description.length > 80 ?
                listing.description.substring(0, 80) + "..." :
                listing.description %>
              </p>
              <div
                class="d-flex justify-content-between align-items-center mt-3"
              >
                <div>
                  <span
                    class="fw-bold text-dark price"
                    data-base="<%= listing.price %>"
                  >
                    &#8377;<%= listing.price.toLocaleString("en-in") %>
                  </span>
                  <span class="text-muted">/ Night</span>
                </div>
                <small class="text-secondary tax-label">+18% GST</small>
              </div>
            </div>
          </div>
        </a>
      </div>
      <% }) %>
    </div>
  </div>

  <script src="/../js/index.js"></script>
</body>
